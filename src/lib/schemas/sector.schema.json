{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["slug", "title", "description"],
    "additionalProperties": false,
    "properties": {
      "slug": { "$ref": "sector-slug" },
      "title": { "type": "string", "minLength": 1 },
      "description": { "type": "string" }
    }
  }
}