{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["title", "source_url", "type", "date_made", "sector", "impact"],
    "additionalProperties": false,
    "properties": {
      "title": { "type": "string", "minLength": 1 },
      "description": { "type": "string" },
      "source_url": { "type": "string", "format": "uri" },
      "type": {
        "type": "string",
        "enum": ["corruption", "mismanagement", "policy_failure", "other"]
      },
      "date_made":    { "type": "string", "format": "date" },
      "created_by": { "type": ["string", "null"] },
      "sector": { "$ref": "sector-slug" },
      "impact": {
        "type": "string",
        "enum": ["low", "medium", "high"]
      },
      "notes": { "type": ["string", "null"] }
    }
  }
}