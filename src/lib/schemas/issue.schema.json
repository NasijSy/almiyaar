{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "title",
      "sector",
      "impact"
    ],
    "additionalProperties": false,
    "properties": {
      "title": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string"
      },
      "sector": {
        "$ref": "sector-slug"
      },
      "impact": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high"
        ]
      },
      "notes": {
        "type": [
          "string",
          "null"
        ]
      }
    }
  }
}